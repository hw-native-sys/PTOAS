// RUN: ptoas %s 2>&1 1>/dev/null | FileCheck %s

module attributes {"pto.device-spec" = "Ascend910B1"} {
  func.func @callee(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> {
    return %src : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
  }

  func.func @caller(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> {
    %c0 = arith.constant 0 : index
    %ret = func.call @callee(%src) : (!pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %sub = pto.subset %ret[%c0, %c0] sizes [32, 32] : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    return %sub : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
  }
}

// CHECK-LABEL: func.func @caller(
// CHECK-SAME: %[[SRC:.*]]: memref<32x32xf32, strided<[32, 1], offset: ?>, #pto.address_space<vec>>
// CHECK-SAME: %[[VC:.*]]: index)
// CHECK-NOT: res_attrs =
// CHECK: %[[RET:.*]] = call @callee(%[[SRC]], %[[VC]])
// CHECK: %[[SUBVIEW:.*]] = memref.subview %[[RET]]
// CHECK: arith.index_cast %[[VC]] : index to i64
// CHECK: pto.bind_tile %[[SUBVIEW]], %{{.*}}, %{{.*}}
// CHECK-NOT: pto.bind_tile %[[SUBVIEW]], %c32, %c32
// CHECK-LABEL: __global__ AICORE __ubuf__ float* caller(
// CHECK: Tile<TileType::Vec, float, 32, 32, BLayout::RowMajor, 32, -1, SLayout::NoneBox, 512, PadValue::Null>
