// RUN: ptoas %s 2>&1 1>/dev/null | FileCheck %s

module attributes {"pto.device-spec" = "Ascend910B1"} {
  func.func private @sink(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

  func.func @caller(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {
    func.call @sink(%src) : (!pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> ()
    return
  }
}

// CHECK-LABEL: func.func private @sink(
// CHECK-SAME: memref<32x32xf32, strided<[?, ?], offset: ?>, #pto.address_space<vec>>
// CHECK-SAME: index, index)
// CHECK-LABEL: func.func @caller(
// CHECK-SAME: %[[CALLSRC:.*]]: memref<32x32xf32, strided<[?, ?], offset: ?>, #pto.address_space<vec>>
// CHECK-SAME: %[[CALLVR:.*]]: index, %[[CALLVC:.*]]: index)
// CHECK: call @sink(%[[CALLSRC]], %[[CALLVR]], %[[CALLVC]])
