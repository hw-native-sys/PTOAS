// RUN: ptoas %s 2>&1 1>/dev/null | FileCheck %s

module attributes {"pto.device-spec" = "Ascend910B1"} {
  func.func @callee(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> {
    %c0 = arith.constant 0 : index
    %sub = pto.subset %src[%c0, %c0] sizes [32, 32] : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    return %sub : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
  }

  func.func @caller(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0> {
    %ret = func.call @callee(%src) : (!pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    return %ret : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
  }
}

// CHECK-LABEL: func.func @callee(
// CHECK-SAME: %[[SRC:.*]]: memref<32x32xf32, strided<[32, 1], offset: ?>, #pto.address_space<vec>>
// CHECK-SAME: %[[ARGVR:.*]]: index, %[[ARGVC:.*]]: index)
// CHECK-NOT: res_attrs =
// CHECK: %[[SUBVIEW:.*]] = memref.subview %[[SRC]]
// CHECK: arith.index_cast %[[ARGVR]] : index to i64
// CHECK: arith.index_cast %[[ARGVC]] : index to i64
// CHECK: arith.select
// CHECK: pto.bind_tile %[[SUBVIEW]], %{{[0-9]+}}, %{{[0-9]+}}
// CHECK-NOT: pto.bind_tile %[[SUBVIEW]], %c32
// CHECK-LABEL: func.func @caller(
// CHECK-SAME: %[[CALLSRC:.*]]: memref<32x32xf32, strided<[32, 1], offset: ?>, #pto.address_space<vec>>
// CHECK-SAME: %[[CALLVR:.*]]: index, %[[CALLVC:.*]]: index)
// CHECK-NOT: res_attrs =
// CHECK: call @callee(%[[CALLSRC]], %[[CALLVR]], %[[CALLVC]])
