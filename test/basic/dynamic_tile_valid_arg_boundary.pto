// RUN: ptoas %s 2>&1 1>/dev/null | FileCheck %s

module attributes {"pto.device-spec" = "Ascend910B1"} {
  func.func @callee(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {
    return
  }

  func.func @caller(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {
    func.call @callee(%src) : (!pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> ()
    return
  }
}

// CHECK-LABEL: func.func @callee(
// CHECK-SAME: %[[SRC:.*]]: memref<32x32xf32, strided<[32, 1], offset: ?>, #pto.address_space<vec>>
// CHECK-SAME: %[[ARGVR:.*]]: index, %[[ARGVC:.*]]: index)
// CHECK-NOT: res_attrs =
// CHECK-LABEL: func.func @caller(
// CHECK-SAME: %[[CALLSRC:.*]]: memref<32x32xf32, strided<[32, 1], offset: ?>, #pto.address_space<vec>>
// CHECK-SAME: %[[CALLVR:.*]]: index, %[[CALLVC:.*]]: index)
// CHECK-NOT: res_attrs =
// CHECK: call @callee(%[[CALLSRC]], %[[CALLVR]], %[[CALLVC]])
