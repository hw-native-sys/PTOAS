// RUN: ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s --check-prefix=A3

module attributes {pto.target_arch = "a3"} {
  func.func @tquant_a3_int8_forms() {
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %scale = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=1, v_row=8, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %offset = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=1, v_row=8, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst_s8 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i8, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst_u8 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=ui8, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tquant ins(%src, %scale : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=1, v_row=8, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%dst_s8 : !pto.tile_buf<loc=vec, dtype=i8, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tquant ins(%src, %scale, %offset : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=1, v_row=8, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=1, v_row=8, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%dst_u8 : !pto.tile_buf<loc=vec, dtype=ui8, rows=8, cols=32, v_row=8, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {quantType = #pto.quant_type<int8_asym>}
    return
  }
}

// A3: ptoas_tquant_scale<QuantType::INT8_SYM
// A3: ptoas_tquant_scale_offset<QuantType::INT8_ASYM
