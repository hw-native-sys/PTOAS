// RUN: ptoas %s | FileCheck %s

module {
  func.func @set_validshape_arg_lowering(
      %arg0: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?,
                           blayout=row_major, slayout=none_box, fractal=512, pad=0>) {
    %c16 = arith.constant 16 : index
    %c24 = arith.constant 24 : index
    pto.set_validshape %arg0, %c16, %c24
      : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=?, v_col=?,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    return
  }
}

// CHECK: Tile<TileType::Vec, float, 32, 32, BLayout::RowMajor, 32, 32, SLayout::NoneBox, 512, PadValue::Null> [[TILE:v[0-9]+]];
// CHECK: uint64_t [[ADDR:v[0-9]+]] = reinterpret_cast<uint64_t>([[ARG:v[0-9]+]]);
// CHECK: TASSIGN([[TILE]], [[ADDR]]);
// CHECK: [[TILE]].RowMaskInternal = [[ROW:v[0-9]+]];
// CHECK: [[TILE]].ColMaskInternal = [[COL:v[0-9]+]];
