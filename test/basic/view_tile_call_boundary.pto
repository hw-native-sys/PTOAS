// RUN: ptoas %s 2>&1 1>/dev/null | FileCheck %s

module attributes {"pto.device-spec" = "Ascend910B1"} {
  func.func @callee(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {
    return
  }

  func.func @caller(%src: !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=64, v_row=32, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {
    %c0 = arith.constant 0 : index
    %sub = pto.subset %src[%c0, %c0] sizes [32, 32] : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=64, v_row=32, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    func.call @callee(%sub) : (!pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) -> ()
    return
  }
}

// CHECK-LABEL: func.func @callee(
// CHECK-SAME: %[[CALLEESRC:.*]]: memref<32x32xf32, strided<[?, ?], offset: ?>, #pto.address_space<vec>>
// CHECK-LABEL: func.func @caller(
// CHECK-SAME: %[[CALLERSRC:.*]]: memref<32x64xf32, strided<[?, ?], offset: ?>, #pto.address_space<vec>>
// CHECK: %[[SUBVIEW:.*]] = memref.subview %[[CALLERSRC]][0, 0] [32, 32] [1, 1]
// CHECK: %[[BIND:.*]] = pto.bind_tile %[[SUBVIEW]]
// CHECK: call @callee(%[[BIND]])
