// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s --check-prefix=A5

module attributes {pto.target_arch = "a5"} {
  func.func @trandom_rounds10() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %k0 = arith.constant 305419896 : i32
    %k1 = arith.constant -1698898192 : i32
    %c0 = arith.constant 0 : i32
    %c1 = arith.constant 1 : i32
    %c2 = arith.constant 2 : i32
    %c3 = arith.constant 3 : i32
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i32, rows=4, cols=256, v_row=4, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.trandom ins(%k0, %k1, %c0, %c1, %c2, %c3 : i32, i32, i32, i32, i32, i32)
                outs(%dst : !pto.tile_buf<loc=vec, dtype=i32, rows=4, cols=256, v_row=4, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }

  func.func @trandom_rounds7() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %k0 = arith.constant 324508639 : i32
    %k1 = arith.constant 610839776 : i32
    %c0 = arith.constant 16 : i32
    %c1 = arith.constant 32 : i32
    %c2 = arith.constant 48 : i32
    %c3 = arith.constant 64 : i32
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=ui32, rows=2, cols=256, v_row=2, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.trandom ins(%k0, %k1, %c0, %c1, %c2, %c3 {rounds = 7 : i32} : i32, i32, i32, i32, i32, i32)
                outs(%dst : !pto.tile_buf<loc=vec, dtype=ui32, rows=2, cols=256, v_row=2, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// A5: template <uint16_t Rounds, typename DstTile>
// A5-LABEL: AICORE void trandom_rounds10(
// A5: PTOAS__TRANDOM<10>(
// A5-LABEL: AICORE void trandom_rounds7(
// A5: PTOAS__TRANDOM<7>(
